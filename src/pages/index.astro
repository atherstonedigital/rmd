---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { siteConfig } from '@/data/siteConfig';
import { buildLocalBusiness, buildOrganization, buildWebSite } from '@/lib/schema';

const title = `${siteConfig.name} | Luxury Flooring Installers, West Midlands`;
const description = 'Premium luxury flooring installation in Tamworth and the West Midlands. Approved Karndean and Amtico installers with 20+ years experience. Get a free quote today.';
const canonical = siteConfig.url + '/';

const schemaData = [
  buildLocalBusiness(),
  buildOrganization(),
  buildWebSite(),
];
---

<BaseLayout title={title} description={description} canonical={canonical} schemaData={schemaData} isHomepage={true}>
  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl lg:text-6xl font-display font-bold text-navy">
        Bespoke Luxury Flooring, West Midlands
      </h1>
      <p class="mt-4 text-lg text-mid-grey">Homepage sections coming soon.</p>
      <!-- TODO: build sections — Hero, Brand Logos, Services Grid, Why RMD, Featured Project, Reviews, Showroom CTA, Contact -->
    </div>
  </section>
</BaseLayout>
