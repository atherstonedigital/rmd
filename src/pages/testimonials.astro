---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { siteConfig } from '@/data/siteConfig';
import { testimonials } from '@/data/testimonials';
import { buildAggregateRating } from '@/lib/schema';
import PageHero from '@/components/sections/PageHero.astro';
import Button from '@/components/ui/Button.astro';
import ContactCTA from '@/components/sections/ContactCTA.astro';

const title = 'Customer Reviews & Testimonials | RMD Flooring';
const description = 'Read what our customers say about RMD Flooring. 5-star Google reviews from homeowners across the West Midlands. See why clients like Darren Bent trust us.';
const canonical = siteConfig.url + '/testimonials/';

const schemaData = [buildAggregateRating(testimonials)];

const featured = testimonials.find((t) => t.featured);


function renderStars(count: number) {
  return Array(count).fill('★').join('');
}
---

<BaseLayout title={title} description={description} canonical={canonical} schemaData={schemaData}>
  <PageHero
    title="Customer Reviews"
    breadcrumbs={[
      { label: 'Home', href: '/' },
      { label: 'Testimonials' },
    ]}
  />

  <!-- Featured: Darren Bent -->
  {featured && (
    <section class="bg-[#0F2035] py-16 lg:py-24">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
          <div>
            <div class="w-16 h-1 bg-amber mb-8"></div>
            <p class="text-xs text-amber uppercase tracking-widest mb-4 font-heading font-semibold">
              Featured Review
            </p>
            <h2 class="text-3xl font-display font-bold text-white mb-6">
              {featured.author}
            </h2>
            <div class="text-amber text-lg mb-4">{renderStars(featured.rating)}</div>
            <blockquote class="text-lg lg:text-xl text-white/80 italic font-display leading-relaxed">
              &ldquo;{featured.body}&rdquo;
            </blockquote>
            <p class="mt-4 text-white/50 text-sm">
              {featured.source === 'google' ? 'Google Review' : featured.source} &middot; {featured.date}
            </p>
          </div>
          <div class="rounded-xl overflow-hidden shadow-2xl">
            <img
              src="/images/gallery/featured-project.jpg"
              alt="Karndean luxury vinyl flooring installed in open-plan living area by RMD Flooring for Darren Bent"
              width="800"
              height="600"
              loading="lazy"
              class="w-full h-auto object-cover"
            />
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- All Reviews -->
  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <div class="flex items-center justify-center gap-2 mb-4">
          <span class="text-2xl text-amber">★★★★★</span>
          <span class="text-2xl font-display font-bold text-navy">5.0</span>
        </div>
        <h2 class="text-3xl font-display font-bold text-navy">
          Google Reviews
        </h2>
        <p class="mt-3 text-mid-grey">
          Every review is from a verified Google customer
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8 max-w-4xl mx-auto">
        {testimonials.map((review) => (
          <div class="bg-white rounded-xl shadow-md border border-stone-200 p-6 lg:p-8">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 rounded-full bg-navy flex items-center justify-center">
                <span class="text-white font-heading font-semibold text-sm">
                  {review.author.charAt(0)}
                </span>
              </div>
              <div>
                <p class="font-heading font-semibold text-navy">{review.author}</p>
                <p class="text-xs text-mid-grey">Google Review &middot; {review.date}</p>
              </div>
            </div>
            <div class="text-amber text-sm mb-3">{renderStars(review.rating)}</div>
            <p class="text-charcoal text-sm leading-relaxed">{review.body}</p>
          </div>
        ))}
      </div>

      <div class="text-center mt-12">
        <p class="text-mid-grey mb-4">
          Had a great experience with RMD Flooring? We&rsquo;d love to hear about it.
        </p>
        <Button href="/contact/" variant="primary" size="md">
          Leave Us a Review
        </Button>
      </div>
    </div>
  </section>

  <ContactCTA />
</BaseLayout>
