---
import { siteConfig, navLinks } from '@/data/siteConfig';
import Button from '@/components/ui/Button.astro';

interface Props {
  isHomepage?: boolean;
}

const { isHomepage = false } = Astro.props;
const currentPath = Astro.url.pathname;
---

<header
  id="site-header"
  class:list={[
    'fixed top-0 left-0 right-0 z-40 transition-all duration-300',
    isHomepage ? 'bg-transparent' : 'bg-navy shadow-lg',
  ]}
  data-homepage={isHomepage}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 group">
        <span class="text-xl lg:text-2xl font-display font-bold text-white tracking-tight">
          RMD Flooring
        </span>
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden lg:flex items-center gap-1" aria-label="Main navigation">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              'px-3 py-2 text-sm font-medium rounded transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-amber',
              currentPath === link.href
                ? 'text-amber bg-white/10'
                : 'text-white/90 hover:text-white hover:bg-white/10',
            ]}
            aria-current={currentPath === link.href ? 'page' : undefined}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Desktop CTA + Phone -->
      <div class="hidden lg:flex items-center gap-4">
        <a
          href={`tel:${siteConfig.phone.showroom.replace(/\s/g, '')}`}
          class="text-sm text-white/90 hover:text-amber transition-all duration-200"
        >
          {siteConfig.phone.showroom}
        </a>
        <Button href="/contact/" variant="primary" size="sm">
          Get a Quote
        </Button>
      </div>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        type="button"
        class="lg:hidden text-white p-2 rounded focus:outline-none focus:ring-2 focus:ring-amber"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Open navigation menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu Drawer -->
  <div
    id="mobile-menu"
    class="lg:hidden fixed inset-0 z-50 hidden"
    role="dialog"
    aria-modal="true"
    aria-label="Navigation menu"
  >
    <!-- Backdrop -->
    <div id="mobile-backdrop" class="absolute inset-0 bg-black/50"></div>

    <!-- Drawer -->
    <div class="absolute right-0 top-0 h-full w-80 max-w-[85vw] bg-navy shadow-xl transform translate-x-full transition-transform duration-300" id="mobile-drawer">
      <div class="flex items-center justify-between p-4 border-b border-white/10">
        <span class="text-lg font-display font-bold text-white">RMD Flooring</span>
        <button
          id="mobile-close-btn"
          type="button"
          class="text-white p-2 rounded focus:outline-none focus:ring-2 focus:ring-amber"
          aria-label="Close navigation menu"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <nav class="p-4 flex flex-col gap-1" aria-label="Mobile navigation">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              'px-4 py-3 text-base font-medium rounded transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-amber',
              currentPath === link.href
                ? 'text-amber bg-white/10'
                : 'text-white/90 hover:text-white hover:bg-white/10',
            ]}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <div class="p-4 border-t border-white/10 space-y-3">
        <a
          href={`tel:${siteConfig.phone.showroom.replace(/\s/g, '')}`}
          class="block text-center text-white/90 hover:text-amber transition-all duration-200"
        >
          {siteConfig.phone.showroom}
        </a>
        <Button href="/contact/" variant="primary" size="md" class="w-full text-center">
          Get a Quote
        </Button>
      </div>
    </div>
  </div>
</header>

<!-- Spacer for fixed header on inner pages -->
{!isHomepage && <div class="h-16 lg:h-20"></div>}

<script>
  // Mobile menu toggle
  const menuBtn = document.getElementById('mobile-menu-btn');
  const closeBtn = document.getElementById('mobile-close-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const backdrop = document.getElementById('mobile-backdrop');
  const drawer = document.getElementById('mobile-drawer');

  function openMenu() {
    mobileMenu?.classList.remove('hidden');
    menuBtn?.setAttribute('aria-expanded', 'true');
    requestAnimationFrame(() => {
      drawer?.classList.remove('translate-x-full');
      drawer?.classList.add('translate-x-0');
    });
  }

  function closeMenu() {
    drawer?.classList.remove('translate-x-0');
    drawer?.classList.add('translate-x-full');
    menuBtn?.setAttribute('aria-expanded', 'false');
    setTimeout(() => mobileMenu?.classList.add('hidden'), 300);
  }

  menuBtn?.addEventListener('click', openMenu);
  closeBtn?.addEventListener('click', closeMenu);
  backdrop?.addEventListener('click', closeMenu);

  // Scroll behaviour for homepage — transparent → solid
  const header = document.getElementById('site-header');
  if (header?.dataset.homepage === 'true') {
    function handleScroll() {
      if (window.scrollY > 50) {
        header?.classList.remove('bg-transparent');
        header?.classList.add('bg-navy', 'shadow-lg');
      } else {
        header?.classList.remove('bg-navy', 'shadow-lg');
        header?.classList.add('bg-transparent');
      }
    }
    window.addEventListener('scroll', handleScroll, { passive: true });
    handleScroll();
  }
</script>
