---
import { cn } from '@/lib/utils';

interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
  type?: 'button' | 'submit' | 'reset';
  [key: string]: unknown;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  class: className,
  type = 'button',
  ...rest
} = Astro.props;

const baseClasses =
  'inline-flex items-center justify-center font-heading font-semibold rounded transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-warm-white';

const variantClasses = {
  primary:
    'bg-navy text-white hover:bg-navy-light focus:ring-amber hover:ring-2 hover:ring-amber',
  secondary:
    'border-2 border-navy text-navy hover:bg-navy hover:text-white focus:ring-navy',
  ghost:
    'text-navy hover:bg-navy/5 focus:ring-navy',
};

const sizeClasses = {
  sm: 'px-4 py-2 text-sm',
  md: 'px-6 py-3 text-base',
  lg: 'px-8 py-4 text-lg',
};

const classes = cn(baseClasses, variantClasses[variant], sizeClasses[size], className);

const Tag = href ? 'a' : 'button';
---

{href ? (
  <a href={href} class={classes} {...rest}>
    <slot />
  </a>
) : (
  <button type={type} class={classes} {...rest}>
    <slot />
  </button>
)}
