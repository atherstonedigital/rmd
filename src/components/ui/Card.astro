---
import { cn } from '@/lib/utils';

interface Props {
  title?: string;
  body?: string;
  image?: string;
  imageAlt?: string;
  href?: string;
  class?: string;
}

const { title, body, image, imageAlt = '', href, class: className } = Astro.props;

const cardClasses = cn(
  'bg-white rounded-xl shadow-md border border-stone-200 overflow-hidden transition-all duration-200',
  href && 'hover:shadow-lg hover:-translate-y-0.5',
  className
);
---

{href ? (
  <a href={href} class={cn(cardClasses, 'block')}>
    {image && (
      <img
        src={image}
        alt={imageAlt}
        width="600"
        height="400"
        loading="lazy"
        class="w-full h-48 object-cover"
      />
    )}
    <div class="p-6">
      {title && <h3 class="text-lg font-heading font-semibold text-navy mb-2">{title}</h3>}
      {body && <p class="text-sm text-mid-grey leading-relaxed">{body}</p>}
      <slot />
    </div>
  </a>
) : (
  <div class={cardClasses}>
    {image && (
      <img
        src={image}
        alt={imageAlt}
        width="600"
        height="400"
        loading="lazy"
        class="w-full h-48 object-cover"
      />
    )}
    <div class="p-6">
      {title && <h3 class="text-lg font-heading font-semibold text-navy mb-2">{title}</h3>}
      {body && <p class="text-sm text-mid-grey leading-relaxed">{body}</p>}
      <slot />
    </div>
  </div>
)}
