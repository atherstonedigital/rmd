---
import { cn } from '@/lib/utils';

interface Props {
  variant?: 'default' | 'outline';
  class?: string;
}

const { variant = 'default', class: className } = Astro.props;

const variants = {
  default: 'bg-navy text-white',
  outline: 'border border-navy text-navy bg-transparent',
};
---

<span
  class={cn(
    'inline-flex items-center rounded-full px-3 py-1 text-xs font-medium tracking-wide uppercase',
    variants[variant],
    className,
  )}
>
  <slot />
</span>
