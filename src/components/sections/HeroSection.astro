---
import Button from '@/components/ui/Button.astro';
import BackgroundBeams from '@/components/react/aceternity/BackgroundBeams';
import BlurIn from '@/components/react/BlurIn';
import ShimmerText from '@/components/react/magicui/ShimmerText';
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden bg-navy-dark">
  <!-- Background Beams -->
  <BackgroundBeams client:load className="absolute inset-0 z-0" />

  <!-- Content -->
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center py-20">
    <!-- Approved Installer label -->
    <div class="mb-6">
      <ShimmerText client:load className="text-xs sm:text-sm font-heading font-medium uppercase tracking-[0.2em]">
        Approved Karndean & Amtico Installers
      </ShimmerText>
    </div>

    <!-- Main headline with blur-in animation -->
    <BlurIn client:load delay={0.3} duration={1}>
      <h1 class="text-5xl sm:text-6xl lg:text-7xl xl:text-8xl font-display font-bold text-white leading-[1.1] tracking-tight">
        Bespoke Luxury Flooring
      </h1>
    </BlurIn>

    <!-- Subheadline -->
    <BlurIn client:load delay={0.6} duration={0.8}>
      <p class="mt-6 text-lg sm:text-xl text-white/70 max-w-xl mx-auto font-sans leading-relaxed">
        Over 20 years transforming homes across Tamworth and the West Midlands
        with premium Karndean, Amtico and luxury vinyl flooring.
      </p>
    </BlurIn>

    <!-- CTAs -->
    <BlurIn client:load delay={0.9} duration={0.8}>
      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
        <Button
          href="/contact/"
          variant="primary"
          size="lg"
          class="bg-amber text-navy hover:bg-amber-light font-bold rounded-full w-full sm:w-auto px-8"
        >
          Get a Free Quote
        </Button>
        <Button
          href="/gallery/"
          variant="secondary"
          size="lg"
          class="border-white text-white hover:bg-white hover:text-navy rounded-full w-full sm:w-auto px-8"
        >
          View Our Work
        </Button>
      </div>
    </BlurIn>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 animate-bounce">
    <svg class="w-6 h-6 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>
