---
import Button from '@/components/ui/Button.astro';
import ScrollReveal from '@/components/react/ScrollReveal';
---

<section class="bg-navy-dark py-24 lg:py-32 overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <!-- Text -->
      <ScrollReveal client:visible direction="left">
        <div>
          <div class="w-16 h-1 bg-amber mb-8"></div>
          <p class="text-3xl lg:text-4xl xl:text-5xl font-display italic text-white leading-tight mb-8">
            &ldquo;Trusted by Premier League professionals.&rdquo;
          </p>
          <p class="text-white/60 leading-relaxed max-w-lg">
            We were honoured to transform the home of former England and Premier League
            footballer Darren Bent. Exceptional quality — that&rsquo;s the RMD standard.
          </p>
          <div class="mt-8">
            <Button href="/testimonials/" variant="secondary" size="md" class="border-white text-white hover:bg-white hover:text-navy rounded-xl">
              Read the Full Story
            </Button>
          </div>
        </div>
      </ScrollReveal>

      <!-- Image -->
      <ScrollReveal client:visible direction="right" delay={0.2}>
        <div class="relative">
          <div class="rounded-2xl overflow-hidden shadow-2xl ring-1 ring-amber/20">
            <img
              src="/images/gallery/featured-project.jpg"
              alt="Karndean luxury vinyl flooring installed in open-plan living area by RMD Flooring"
              width="800"
              height="600"
              loading="lazy"
              class="w-full h-auto object-cover"
            />
          </div>
          <!-- Decorative accent -->
          <div class="absolute -bottom-4 -right-4 w-32 h-32 border-2 border-amber/20 rounded-2xl -z-10"></div>
        </div>
      </ScrollReveal>
    </div>
  </div>
</section>
