---
import { siteConfig } from '@/data/siteConfig';
import Button from '@/components/ui/Button.astro';
import ScrollReveal from '@/components/react/ScrollReveal';

const address = siteConfig.address;
const mapsQuery = encodeURIComponent(
  `${address.street}, ${address.locality}, ${address.town}, ${address.postcode}`
);
const mapsUrl = `https://www.google.com/maps/search/?api=1&query=${mapsQuery}`;
---

<section class="relative bg-navy-dark py-24 lg:py-32 overflow-hidden grain">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <ScrollReveal client:visible>
      <div class="text-center max-w-2xl mx-auto">
        <h2 class="text-3xl lg:text-4xl font-display font-bold text-white mb-4">
          Visit Our Showroom
        </h2>
        <p class="text-lg text-white/60 mb-8">
          See and feel our flooring samples in person. Our Tamworth showroom is the
          perfect place to explore your options with expert guidance.
        </p>

        <!-- Address -->
        <address class="not-italic text-white/80 font-heading font-medium mb-4">
          <p>{address.street}, {address.locality}</p>
          <p>{address.town}, {address.postcode}</p>
        </address>

        <!-- Opening hours -->
        <div class="text-sm text-white/50 mb-8">
          {siteConfig.openingHours.map((item) => (
            <p>
              <span class="text-white/70">{item.label}:</span> {item.hours}
            </p>
          ))}
        </div>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <Button href={mapsUrl} variant="primary" size="md" class="bg-amber text-navy hover:bg-amber-light rounded-full w-full sm:w-auto px-8">
            Get Directions
          </Button>
          <Button href={siteConfig.phone.showroomTel} variant="secondary" size="md" class="border-white text-white hover:bg-white hover:text-navy rounded-full w-full sm:w-auto px-8">
            Call Us
          </Button>
        </div>
      </div>
    </ScrollReveal>
  </div>
</section>
