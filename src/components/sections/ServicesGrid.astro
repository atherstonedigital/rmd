---
import { services } from '@/data/services';

const displayServices = services.filter((s) => s.id !== 'wet-rooms');

const iconPaths: Record<string, string> = {
  Layers: 'M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5',
  LayoutGrid: 'M3 3h7v7H3zM14 3h7v7h-7zM3 14h7v7H3zM14 14h7v7h-7z',
  Hammer: 'M15.12 7.88c.39-.39 1.02-.39 1.41 0l2.12 2.12c.39.39.39 1.02 0 1.41L7.05 23.01 2 21l1.99-5.05L15.12 7.88zM17.59 3.59l2.83 2.83',
  Scissors: 'M6 9a3 3 0 100-6 3 3 0 000 6zM6 21a3 3 0 100-6 3 3 0 000 6zM20 4L8.12 15.88M14.47 14.48L20 20M8.12 8.12L12 12',
};
---

<section class="bg-off-white py-16 lg:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section heading -->
    <div class="text-center mb-12 lg:mb-16">
      <h2 class="text-3xl lg:text-4xl font-display font-bold text-navy">
        Our Services
      </h2>
      <p class="mt-4 text-lg text-mid-grey max-w-2xl mx-auto">
        Premium flooring installation across the West Midlands. From luxury vinyl
        to bespoke stair runners, every project is fitted to perfection.
      </p>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">
      {displayServices.map((service) => (
        <a
          href={`/${service.slug}/`}
          class="group bg-white rounded-xl shadow-md border border-stone-200 p-6 lg:p-8 transition-all duration-200 hover:shadow-lg hover:-translate-y-1"
        >
          <!-- Icon -->
          <div class="w-12 h-12 rounded-lg bg-amber/10 flex items-center justify-center mb-5">
            <svg
              class="w-6 h-6 text-amber"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              viewBox="0 0 24 24"
            >
              <path d={iconPaths[service.icon] || iconPaths.Layers} />
            </svg>
          </div>

          <!-- Content -->
          <h3 class="text-lg font-heading font-semibold text-navy mb-2 group-hover:text-navy-light transition-all duration-200">
            {service.name}
          </h3>
          <p class="text-sm text-mid-grey leading-relaxed mb-4">
            {service.shortDescription}
          </p>

          <!-- Link arrow -->
          <span class="inline-flex items-center text-sm font-medium text-amber group-hover:gap-2 gap-1 transition-all duration-200">
            Learn More
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
