---
import { testimonials } from '@/data/testimonials';

function renderStars(count: number) {
  return Array(count).fill('★').join('');
}
---

<section class="py-16 lg:py-24 bg-warm-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <div class="flex items-center justify-center gap-2 mb-4">
        <span class="text-2xl text-amber">★★★★★</span>
        <span class="text-2xl font-display font-bold text-navy">5.0</span>
      </div>
      <h2 class="text-3xl lg:text-4xl font-display font-bold text-navy">
        What Our Customers Say
      </h2>
      <p class="mt-3 text-mid-grey">Rated 5 stars on Google</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8 max-w-4xl mx-auto">
      {testimonials.map((review) => (
        <div class="bg-white rounded-xl shadow-md border border-stone-200 p-6 lg:p-8">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-full bg-navy flex items-center justify-center">
              <span class="text-white font-heading font-semibold text-sm">
                {review.author.charAt(0)}
              </span>
            </div>
            <div>
              <p class="font-heading font-semibold text-navy">{review.author}</p>
              <p class="text-xs text-mid-grey">Google Review</p>
            </div>
          </div>
          <div class="text-amber text-sm mb-3">{renderStars(review.rating)}</div>
          <p class="text-charcoal text-sm leading-relaxed">{review.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
