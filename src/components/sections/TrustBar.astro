---
import NumberTicker from '@/components/react/magicui/NumberTicker';

const stats = [
  {
    value: 20,
    suffix: '+',
    label: 'Years of Experience',
    icon: 'M6 9V2h12v7M6 18H4a2 2 0 01-2-2v-5a2 2 0 012-2h16a2 2 0 012 2v5a2 2 0 01-2 2h-2M6 14h12v8H6z',
  },
  {
    value: 5,
    suffix: '',
    label: 'Premium Brand Partners',
    icon: 'M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z',
  },
  {
    value: 2,
    suffix: ' Year',
    label: 'Fitting Guarantee',
    icon: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z',
  },
];
---

<section class="bg-navy py-16 lg:py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 lg:gap-16 text-center">
      {stats.map((stat) => (
        <div class="flex flex-col items-center">
          <svg
            class="w-8 h-8 text-amber mb-4"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            viewBox="0 0 24 24"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d={stat.icon} />
          </svg>
          <div class="text-4xl lg:text-5xl font-display font-bold text-amber">
            <NumberTicker
              client:visible
              value={stat.value}
              suffix={stat.suffix}
              duration={2000}
            />
          </div>
          <span class="mt-2 text-sm lg:text-base text-white/80 font-heading font-medium">
            {stat.label}
          </span>
        </div>
      ))}
    </div>
  </div>
</section>
